# Copy to .env for local development. Never commit real credentials.
ENVIRONMENT=development
CORS_ORIGINS=["http://127.0.0.1:5173"]
DATABASE_URL=postgresql+psycopg://soc_app:replace_me@database:5432/soc_dashboard
DEMO_DATA_ENABLED=true
VITE_API_BASE_URL=/api
VITE_CENTRAL_API_BASE_URL=
VITE_THREAT_API_BASE_URL=http://localhost:8001/api
VITE_AI_API_BASE_URL=http://localhost:8002/api
VITE_ATTACK_API_BASE_URL=http://localhost:8003/api
VITE_API_TIMEOUT_MS=10000
VITE_POLL_INTERVAL_MS=30000
SOC_API_PROXY_TARGET=http://127.0.0.1:8000
POSTGRES_DB=soc_dashboard
POSTGRES_USER=soc_app
POSTGRES_PASSWORD=replace_me
