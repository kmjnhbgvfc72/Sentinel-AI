APP_NAME=AI CTI Threat Intelligence
APP_VERSION=7.0.0
ENVIRONMENT=development
LOG_LEVEL=INFO
DATABASE_URL=postgresql+psycopg://threatintel:replace_with_secure_password@database:5432/threatintel
CORS_ORIGINS=["http://localhost:5177"]
DEMO_DATA_ENABLED=true
FEED_SCHEDULER_ENABLED=false
FEED_SYNC_INTERVAL_MINUTES=60
FEED_REQUEST_TIMEOUT_SECONDS=10
FEED_MAX_BYTES=5000000
ALLOW_PRIVATE_FEED_HOSTS=false
REPUTATION_CACHE_TTL_SECONDS=3600
PHASE3_API_URL=http://host.docker.internal:8001/api
PHASE4_API_URL=http://host.docker.internal:8002/api
PHASE5_API_URL=http://host.docker.internal:8003/api
PHASE6_API_URL=http://host.docker.internal:8004/api
INTEGRATION_TIMEOUT_SECONDS=3
ABUSEIPDB_API_KEY=
VIRUSTOTAL_API_KEY=
POSTGRES_DB=threatintel
POSTGRES_USER=threatintel
POSTGRES_PASSWORD=replace_with_secure_password
VITE_API_URL=http://localhost:8005/api
